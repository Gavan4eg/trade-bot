# Bybit API credentials
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=true
PAPER_TRADING=true  # Симуляция без реальных сделок

# Trading settings
MAX_POSITIONS=3
RISK_PER_TRADE=1.0
MIN_RR=2.0
RANGE_TIMEFRAME=1h
RANGE_CANDLES=24

# Confirmation settings
MIN_CONFIRMATIONS=2
SWEEP_THRESHOLD_PERCENT=0.1
VOLUME_SPIKE_MULTIPLIER=2.0

# TP/SL settings
TP1_RR=2.0
TP1_CLOSE_PERCENT=50
TP2_RR=3.0
TP2_CLOSE_PERCENT=30
TRAILING_ACTIVATION_RR=2.5
TRAILING_STEP_PERCENT=0.5

# Server settings
HOST=0.0.0.0
PORT=8000
